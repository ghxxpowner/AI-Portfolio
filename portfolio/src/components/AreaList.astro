---
interface Props {
  areas: string[];
}

const { areas } = Astro.props;
---

<ul role="list" class="area-list" data-reveal>
  {
    areas.map((area, i) => (
      <li class="area-item" data-reveal-item style={`--index: ${i}`}>
        <span class="area-label">{area}</span>
      </li>
    ))
  }
</ul>

<style>
  .area-list {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(min(15rem, 100%), 1fr));
    gap: var(--space-md) var(--space-lg);
    margin: 0;
    padding: 0;
  }

  .area-item {
    display: flex;
    align-items: center;
  }

  .area-label {
    font-size: var(--text-md);
    font-weight: 600;
    letter-spacing: var(--tracking-tight);
    text-wrap: balance;
  }
</style>

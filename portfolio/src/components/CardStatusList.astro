---
export interface StatusCard {
  id: string;
  title: string;
  status: 'completed' | 'updates-found' | 'syncing';
}

interface Props {
  title?: string;
  caption?: string;
  cards?: StatusCard[];
}

const defaultCards: StatusCard[] = [
  { id: 'foundation', title: 'Foundation tokens', status: 'completed' },
  { id: 'icons', title: 'Icon library', status: 'completed' },
  { id: 'core', title: 'Core component library', status: 'completed' },
  { id: 'player', title: 'Player', status: 'updates-found' },
  { id: 'portal', title: 'Streaming portal', status: 'updates-found' },
  { id: 'pages', title: 'Page templates', status: 'syncing' },
];

const {
  title = 'Single source of truth',
  caption = 'Figma, Zeroheight and Storybook — reconciled into one library.',
  cards = defaultCards,
} = Astro.props;

// Completed first, original order preserved within each group.
const rank = (s: StatusCard['status']) => (s === 'completed' ? 0 : 1);
const sorted = [...cards].sort((a, b) => rank(a.status) - rank(b.status));

const labels: Record<StatusCard['status'], string> = {
  completed: '',
  'updates-found': 'Updates found',
  syncing: 'Syncing',
};

// Eight tick marks around the syncing dial (mirrors the source component's geometry).
const dashes = Array.from({ length: 8 }, (_, i) => {
  const a = ((i * 45 - 90) * Math.PI) / 180;
  const r = 6;
  const d = 1.8;
  return {
    x1: 8 + (r - d / 2) * Math.cos(a),
    y1: 8 + (r - d / 2) * Math.sin(a),
    x2: 8 + (r + d / 2) * Math.cos(a),
    y2: 8 + (r + d / 2) * Math.sin(a),
  };
});
const head = dashes[0];
---

<section class="csl" data-card-status data-reveal aria-label={title}>
  <div class="csl-panel">
    <header class="csl-head" data-reveal-item style="--index: 0">
      <h3 class="csl-title">{title}</h3>
      {caption && <p class="csl-caption">{caption}</p>}
    </header>

    <ul role="list" class="csl-list">
      {
        sorted.map((card, i) => (
          <li
            class="csl-card"
            data-card
            data-status={card.status}
            data-reveal-item
            style={`--index: ${i + 1}`}
          >
            <div class="csl-card-inner">
              <span class="csl-status" aria-hidden="true">
                <span class="ic ic-done">
                  <svg viewBox="0 0 16 16" width="16" height="16">
                    <circle cx="8" cy="8" r="8" fill="var(--color-accent)" />
                    <path
                      d="M5 8l2.5 2.5 3.5-4"
                      stroke="var(--color-on-accent)"
                      stroke-width="1.6"
                      fill="none"
                      stroke-linecap="round"
                      stroke-linejoin="round"
                    />
                  </svg>
                </span>
                <span class="ic ic-updates">
                  <svg viewBox="0 0 16 16" width="16" height="16">
                    <circle cx="8" cy="8" r="6.5" fill="none" stroke="currentColor" stroke-width="1.5" />
                    <circle cx="8" cy="8" r="2" fill="currentColor" />
                  </svg>
                </span>
                <span class="ic ic-sync">
                  <svg viewBox="0 0 16 16" width="16" height="16">
                    {dashes.map((d) => (
                      <line
                        x1={d.x1}
                        y1={d.y1}
                        x2={d.x2}
                        y2={d.y2}
                        stroke="var(--color-text-muted)"
                        stroke-width="2"
                        stroke-linecap="round"
                      />
                    ))}
                    <g class="csl-sync-head">
                      <line
                        x1={head.x1}
                        y1={head.y1}
                        x2={head.x2}
                        y2={head.y2}
                        stroke="var(--color-accent)"
                        stroke-width="2"
                        stroke-linecap="round"
                      />
                    </g>
                  </svg>
                </span>
              </span>

              <span class="csl-card-title">{card.title}</span>

              <span class="csl-right">
                <span class="csl-label" data-label aria-hidden="true">
                  {labels[card.status]}
                </span>
                <button class="csl-sync-btn" type="button" data-sync aria-label={`Synchronize ${card.title}`}>
                  Synchronize
                </button>
              </span>
            </div>
          </li>
        ))
      }
    </ul>
  </div>
</section>

<style>
  .csl {
    --flow-space: var(--space-xl);
  }

  .csl-panel {
    padding: var(--space-lg);
    background-color: var(--color-bg-subtle);
    border: var(--border-hairline);
    border-radius: var(--radius-2xl);
  }

  .csl-head {
    margin-block-end: var(--space-lg);
  }

  .csl-title {
    font-size: var(--text-xl);
    font-weight: 650;
    letter-spacing: var(--tracking-tight);
  }

  .csl-caption {
    margin-block-start: var(--space-2xs);
    font-size: var(--text-sm);
    color: var(--color-text-muted);
  }

  .csl-list {
    display: grid;
    gap: var(--space-sm);
    margin: 0;
    padding: 0;
    list-style: none;
  }

  .csl-card {
    position: relative;
    padding: var(--space-md) var(--space-lg);
    background-color: var(--color-surface);
    border: var(--border-hairline);
    border-radius: var(--radius-xl);
    transition:
      border-color var(--duration-quick) var(--ease-out-cubic),
      translate var(--duration-quick) var(--ease-out-cubic);
  }

  .csl-card:hover {
    translate: 0 -1px;
    border-color: var(--color-border-strong);
  }

  /* A subtle wash from the trailing edge for non-completed states. */
  .csl-card[data-status='updates-found']::after,
  .csl-card[data-status='syncing']::after {
    content: '';
    position: absolute;
    inset: 0;
    border-radius: inherit;
    background: linear-gradient(
      to left,
      color-mix(in srgb, var(--color-accent) 14%, transparent),
      transparent 40%
    );
    pointer-events: none;
  }

  .csl-card-inner {
    position: relative;
    display: flex;
    align-items: center;
    gap: var(--space-md);
  }

  .csl-status {
    display: grid;
    place-items: center;
    inline-size: 1.25rem;
    block-size: 1.25rem;
    flex-shrink: 0;
  }

  .csl-status .ic {
    display: none;
    place-items: center;
    color: var(--color-text-muted);
  }

  .csl-card[data-status='completed'] .ic-done,
  .csl-card[data-status='updates-found'] .ic-updates,
  .csl-card[data-status='syncing'] .ic-sync {
    display: grid;
  }

  .csl-card-title {
    flex: 1;
    min-inline-size: 0;
    font-size: var(--text-md);
    color: var(--color-text);
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  /* Right slot: label and Synchronize button share one cell and crossfade. */
  .csl-right {
    position: relative;
    display: grid;
    place-items: center end;
    min-block-size: 1.75rem;
    min-inline-size: 6.5rem;
    flex-shrink: 0;
  }

  .csl-label,
  .csl-sync-btn {
    grid-area: 1 / 1;
    justify-self: end;
  }

  .csl-label {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    font-weight: 600;
    letter-spacing: var(--tracking-wide);
    text-transform: uppercase;
    color: var(--color-text-muted);
    white-space: nowrap;
    transition: opacity var(--duration-quick) var(--ease-out-cubic);
  }

  /* Completed cards carry no trailing text. */
  .csl-card[data-status='completed'] .csl-label {
    display: none;
  }

  .csl-sync-btn {
    padding: var(--space-2xs) var(--space-md);
    font: inherit;
    font-size: var(--text-xs);
    font-weight: 600;
    white-space: nowrap;
    color: var(--color-on-accent);
    background-color: var(--color-accent);
    border: none;
    border-radius: var(--radius-full);
    cursor: pointer;
    /* Present and focusable only for updates-found; revealed on hover/focus. */
    display: none;
    opacity: 0;
    transition: opacity var(--duration-quick) var(--ease-out-cubic);
  }

  .csl-card[data-status='updates-found'] .csl-sync-btn {
    display: inline-flex;
  }

  .csl-card[data-status='updates-found']:hover .csl-sync-btn,
  .csl-card[data-status='updates-found']:focus-within .csl-sync-btn {
    opacity: 1;
  }

  .csl-card[data-status='updates-found']:hover .csl-label,
  .csl-card[data-status='updates-found']:focus-within .csl-label {
    opacity: 0;
  }

  .csl-sync-btn:focus-visible {
    outline: 2px solid var(--color-focus-ring);
    outline-offset: 2px;
  }

  /* The syncing dial spins and a completed card gives a small pop —
     both only when motion is allowed. */
  .csl-sync-head {
    transform-box: view-box;
    transform-origin: 8px 8px;
  }

  @media (prefers-reduced-motion: no-preference) {
    .csl-card[data-status='syncing'] .csl-sync-head {
      animation: csl-spin 0.8s steps(8) infinite;
    }

    .csl-card.csl-pop {
      animation: csl-pop 0.5s var(--ease-out-cubic);
    }
  }

  @keyframes csl-spin {
    to {
      transform: rotate(360deg);
    }
  }

  @keyframes csl-pop {
    30% {
      scale: 1.02;
    }
  }
</style>

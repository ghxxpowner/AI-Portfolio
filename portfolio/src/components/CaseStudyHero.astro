---
import type { CollectionEntry } from 'astro:content';
import { Image } from 'astro:assets';
import CaseStudyMeta from './CaseStudyMeta.astro';
import Artwork from './artwork/Artwork.astro';
import GlowBlob from './GlowBlob.astro';

interface Props {
  entry: CollectionEntry<'work'>;
}

const { entry } = Astro.props;
const { title, summary, client, year, role, team, timeline, platform, artwork, heroImage } =
  entry.data;

const meta = [
  { term: 'Role', detail: role },
  { term: 'Team', detail: team },
  { term: 'Timeline', detail: timeline },
  { term: 'Platform', detail: platform },
];
---

<header class="cs-hero" data-reveal>
  <GlowBlob size="34rem" top="-16rem" right="-12rem" />

  <div class="cs-id" data-reveal-item style="--index: 0">
    <p class="eyebrow">{client} · {year}</p>
    <h1>{title}</h1>
  </div>

  <div class="cs-meta" data-reveal-item style="--index: 1">
    <CaseStudyMeta items={meta} />
  </div>

  <div class="cs-photo" data-reveal-item style="--index: 2">
    {
      heroImage ? (
        <Image
          class="hero-photo"
          src={heroImage}
          alt=""
          widths={[700, 1200, 1920]}
          sizes="(min-width: 64rem) min(94rem, calc(100vw - 4rem)), 100vw"
          loading="eager"
          fetchpriority="high"
        />
      ) : (
        <Artwork {artwork} />
      )
    }
  </div>

  <p class="summary" data-reveal-item style="--index: 3">{summary}</p>
</header>

<style>
  .cs-hero {
    position: relative;
    display: grid;
    /* minmax(0, 1fr) keeps the breakout photo from stretching the column */
    grid-template-columns: minmax(0, 1fr);
    gap: var(--space-xl);
    padding-block-start: var(--space-2xl);
  }

  .cs-id {
    display: grid;
    gap: var(--space-md);
  }

  h1 {
    max-width: 20ch;
    font-size: var(--text-4xl);
    letter-spacing: var(--tracking-display);
    text-wrap: balance;
  }

  .summary {
    max-width: 60ch;
    font-size: var(--text-xl);
    line-height: var(--leading-snug);
    color: var(--color-text-muted);
    text-wrap: pretty;
  }

  /* Photo breaks out of the reading container: full-bleed on mobile/tablet,
     wider-than-container (but framed) from desktop up. Centered on the viewport
     via left/transform — independent of the reveal's `translate`, so they don't
     conflict. */
  .cs-photo {
    position: relative;
    left: 50%;
    transform: translateX(-50%);
    inline-size: 100vw;
    margin-block-start: var(--space-sm);
  }

  .cs-photo :global(.hero-photo) {
    display: block;
    inline-size: 100%;
    block-size: auto;
  }

  @media (min-width: 64rem) {
    .cs-photo {
      inline-size: min(94rem, calc(100vw - 4rem));
    }

    .cs-photo :global(.hero-photo) {
      border-radius: var(--radius-2xl);
    }
  }
</style>

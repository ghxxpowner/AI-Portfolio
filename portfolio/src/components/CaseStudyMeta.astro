---
interface Props {
  items: { term: string; detail: string }[];
}

const { items } = Astro.props;
---

<dl class="cs-meta-list">
  {
    items.map((item) => (
      <div class="cs-meta-item">
        <dt>{item.term}</dt>
        <dd>{item.detail}</dd>
      </div>
    ))
  }
</dl>

<style>
  /* No cards — just labelled columns under a single hairline rule.
     Two per row, never three; four only once they comfortably fit. */
  .cs-meta-list {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: var(--space-lg);
    margin: 0;
    padding-block-start: var(--space-lg);
    border-block-start: var(--border-hairline);
  }

  @media (min-width: 64rem) {
    .cs-meta-list {
      grid-template-columns: repeat(4, 1fr);
    }
  }

  .cs-meta-item {
    display: grid;
    align-content: start;
    gap: var(--space-2xs);
  }

  dt {
    font-size: var(--text-xs);
    font-weight: 600;
    letter-spacing: var(--tracking-wide);
    text-transform: uppercase;
    color: var(--color-text-muted);
  }

  dd {
    margin: 0;
    font-size: var(--text-md);
    font-weight: 550;
    text-wrap: pretty;
  }
</style>

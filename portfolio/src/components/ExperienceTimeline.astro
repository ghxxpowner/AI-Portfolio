---
import { experience, type ExperienceEntry } from '../data/experience';

interface Props {
  /** Defaults to the shared data source; override only for demos. */
  entries?: ExperienceEntry[];
}

const { entries = experience } = Astro.props;
---

<ol class="exp-list" data-exp-timeline>
  <span class="exp-rail" aria-hidden="true"><span class="exp-rail-fill"></span></span>
  {
    entries.map((entry) => {
      const initial = entry.company.trim().charAt(0).toUpperCase();
      return (
      <li class="exp-item">
        <span class="exp-node" aria-hidden="true" />
        <article class="exp-card">
          <header class="exp-head">
            <div class="exp-titleline">
              <h3 class="exp-role">{entry.role}</h3>
              {entry.current && <span class="exp-now">Now</span>}
            </div>
            <p class="exp-org">
              <span class="exp-logo" aria-hidden="true">{initial}</span>
              <span class="exp-company">
                {entry.companyUrl ? (
                  <a href={entry.companyUrl}>{entry.company}</a>
                ) : (
                  <span>{entry.company}</span>
                )}
              </span>
              <span class="exp-loc">· {entry.location}</span>
            </p>
            <p class="exp-period">
              <time datetime={entry.start}>{entry.start}</time>
              <span aria-hidden="true"> – </span>
              {entry.end ? <time datetime={entry.end}>{entry.end}</time> : <span>Today</span>}
            </p>
          </header>

          <p class="exp-summary">{entry.summary}</p>

          {entry.highlights.length > 0 && (
            <ul class="exp-highlights">
              {entry.highlights.map((h) => (
                <li>{h}</li>
              ))}
            </ul>
          )}

          {entry.skills.length > 0 && (
            <ul class="exp-skills" aria-label="Skills">
              {entry.skills.map((s) => (
                <li class="exp-skill">{s}</li>
              ))}
            </ul>
          )}
        </article>
      </li>
      );
    })
  }
</ol>

<style>
  .exp-list {
    /* Rail + nodes share one center coordinate so they stay aligned. */
    --rail-x: 0.5rem;
    --node-size: 0.9rem;
    --list-pad: var(--space-xl);

    position: relative;
    display: grid;
    /* minmax(0, 1fr) stops the single column from growing to its content's
       max-content width (which would overflow narrow viewports). */
    grid-template-columns: minmax(0, 1fr);
    gap: var(--space-lg);
    margin: 0;
    padding: 0;
    padding-inline-start: var(--list-pad);
    list-style: none;
  }

  @media (min-width: 48rem) {
    .exp-list {
      --list-pad: var(--space-2xl);
      gap: var(--space-xl);
    }
  }

  /* Decorative rail + its progress fill (aria-hidden). */
  .exp-rail {
    position: absolute;
    inset-block: 0.7rem 0.7rem;
    inset-inline-start: calc(var(--rail-x) - 1px);
    inline-size: 2px;
    background-color: var(--color-border);
    border-radius: var(--radius-full);
    overflow: hidden;
  }

  .exp-rail-fill {
    position: absolute;
    inset: 0;
    transform-origin: top;
    background-color: var(--color-accent);
    /* Default (no JS / reduced motion / no scroll-driven support): full. */
    transform: scaleY(1);
  }

  .exp-item {
    position: relative;
  }

  .exp-node {
    position: absolute;
    inset-block-start: 0.45rem;
    /* Node lives inside .exp-item (left edge = --list-pad); this lands its
       center exactly on --rail-x at every breakpoint. */
    inset-inline-start: calc(var(--rail-x) - var(--node-size) / 2 - var(--list-pad));
    inline-size: var(--node-size);
    block-size: var(--node-size);
    background-color: var(--color-accent);
    border: 2px solid var(--color-bg);
    border-radius: var(--radius-full);
  }

  .exp-card {
    display: grid;
    min-inline-size: 0;
    gap: var(--space-sm);
    padding: var(--space-lg);
    background-color: var(--color-surface);
    border: var(--border-hairline);
    border-radius: var(--radius-xl);
  }

  .exp-head {
    display: grid;
    gap: var(--space-2xs);
  }

  .exp-titleline {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: var(--space-sm);
  }

  .exp-role {
    font-size: var(--text-lg);
    font-weight: 650;
    letter-spacing: var(--tracking-tight);
  }

  .exp-now {
    padding: 0.15em 0.6em;
    font-size: var(--text-xs);
    font-weight: 600;
    letter-spacing: var(--tracking-wide);
    text-transform: uppercase;
    color: var(--color-on-accent);
    background-color: var(--color-accent);
    border-radius: var(--radius-full);
  }

  .exp-org {
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: var(--space-xs);
    font-size: var(--text-sm);
    color: var(--color-text-muted);
  }

  /* Circular logo placeholder (monogram). Swap for a real logo later. */
  .exp-logo {
    display: grid;
    place-items: center;
    flex-shrink: 0;
    inline-size: 1.5rem;
    block-size: 1.5rem;
    font-size: var(--text-xs);
    font-weight: 700;
    color: var(--color-text-muted);
    background-color: var(--color-bg-subtle);
    border: var(--border-hairline);
    border-radius: var(--radius-full);
  }

  .exp-org a {
    color: var(--color-text);
    font-weight: 600;
    text-decoration-color: var(--color-accent);
    text-decoration-thickness: 2px;
    text-underline-offset: 3px;
    transition: color var(--duration-quick) var(--ease-out-cubic);
  }

  .exp-org a:hover {
    color: var(--color-text-muted);
  }

  .exp-org a:focus-visible {
    outline: 2px solid var(--color-focus-ring);
    outline-offset: 3px;
    border-radius: var(--radius-sm);
  }

  .exp-period {
    font-size: var(--text-xs);
    font-weight: 600;
    letter-spacing: normal;
    text-transform: uppercase;
    color: var(--color-text-muted);
    font-variant-numeric: tabular-nums;
  }

  .exp-summary {
    font-size: var(--text-sm);
    color: var(--color-text-muted);
    text-wrap: pretty;
  }

  .exp-highlights {
    display: grid;
    gap: var(--space-2xs);
    margin: 0;
    padding-inline-start: 1.15em;
    font-size: var(--text-sm);
    color: var(--color-text);
  }

  .exp-highlights li::marker {
    color: var(--color-text-muted);
  }

  .exp-skills {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2xs);
    margin: 0;
    padding: 0;
    list-style: none;
  }

  .exp-skill {
    padding: var(--space-2xs) var(--space-sm);
    font-size: var(--text-xs);
    font-weight: 600;
    color: var(--color-text);
    background-color: var(--color-bg-subtle);
    border-radius: var(--radius-full);
  }

  /* ----------------------------------------------------------------------
     Motion — only when JS runs (html.js) AND motion is allowed. Without
     either, every station is already visible and active (defaults above):
     no content is ever hidden behind animation.
     ---------------------------------------------------------------------- */
  @media (prefers-reduced-motion: no-preference) {
    /* Nodes start muted, cards start hidden; JS reveals them top-to-bottom. */
    :global(html.js) .exp-node {
      background-color: var(--color-border-strong);
      transition: background-color var(--duration-slow) var(--ease-out-cubic);
    }

    :global(html.js) .exp-item.is-active .exp-node {
      background-color: var(--color-accent);
    }

    :global(html.js) .exp-card {
      opacity: 0;
      transform: translateY(0.6rem);
      transition:
        opacity var(--duration-slow) var(--ease-out-cubic),
        transform var(--duration-slow) var(--ease-out-cubic);
    }

    :global(html.js) .exp-item.is-active .exp-card {
      opacity: 1;
      transform: none;
    }

    /* Progress line — JS fallback drives --exp-progress when scroll-driven
       animations are unavailable. */
    :global(html.js) .exp-rail-fill {
      transform: scaleY(var(--exp-progress, 0));
      will-change: transform;
    }

    /* Preferred: CSS scroll-driven animation — JS-free, bidirectional. */
    @supports (animation-timeline: view()) {
      :global(html.js) .exp-list {
        view-timeline-name: --exp-scroll;
        view-timeline-axis: block;
      }

      :global(html.js) .exp-rail-fill {
        transform: scaleY(0);
        animation: exp-rail-grow linear both;
        animation-timeline: --exp-scroll;
        animation-range: cover;
      }
    }
  }

  @keyframes exp-rail-grow {
    from {
      transform: scaleY(0);
    }
    to {
      transform: scaleY(1);
    }
  }
</style>

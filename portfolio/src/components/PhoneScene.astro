---
import { Image } from 'astro:assets';
import { phoneScreens, type PhoneScreen } from '../data/phone-screens';

// A staggered three-column wall of individual phone mockups with light 2.5D
// depth: phones stay frontal, and depth comes from per-layer scale + opacity
// plus differential parallax speed (near layers drift more than far). Same
// mechanic as MultiDeviceShowcase, scaled to 12 phones.
//
// Motion contract: the static wall is what reduced motion, no-JS, unsupported
// browsers, and small screens get — nothing is ever hidden. Parallax drift is
// layered on top only when motion is allowed AND there's room (≥48rem).

// Depth → scale, opacity and parallax amplitude. Component-local (no tokens).
const depthMap: Record<PhoneScreen['depth'], { scale: string; op: string; amp: string }> = {
  1: { scale: '1', op: '1', amp: '60px' },
  2: { scale: '0.92', op: '0.96', amp: '36px' },
  3: { scale: '0.84', op: '0.9', amp: '21px' },
};

const columns: PhoneScreen[][] = [1, 2, 3].map((c) => phoneScreens.filter((s) => s.column === c));

interface Props {
  caption?: string;
}
const { caption } = Astro.props;
---

<figure class="ps full-width">
  <div class="ps-scene" data-phone-scene>
    {
      columns.map((col) => (
        <ul class="ps-col">
          {col.map((screen) => {
            const d = depthMap[screen.depth];
            return (
              <li
                class="ps-item"
                data-depth={screen.depth}
                style={`--amp: ${d.amp}; --scale: ${d.scale}; --op: ${d.op};`}
              >
                <Image
                  src={screen.image}
                  alt={screen.alt}
                  widths={[375, 750, 1125]}
                  sizes="(min-width: 48rem) 30vw, 45vw"
                  loading="lazy"
                  decoding="async"
                />
              </li>
            );
          })}
        </ul>
      ))
    }
  </div>
  {caption && <figcaption>{caption}</figcaption>}
</figure>

<style>
  .ps {
    --flow-space: var(--space-xl);
    margin: 0;
  }

  /* Base = calm flat 2-column grid. This is what reduced motion, no-JS,
     unsupported browsers, and small screens get — nothing is ever hidden.
     `display: contents` lets the 12 phones flow straight into this grid. */
  .ps-scene {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: var(--space-md);
    max-width: var(--container-max);
    margin-inline: auto;
    padding-inline: var(--gutter);
  }

  .ps-col {
    display: contents;
    list-style: none;
  }

  .ps-item {
    margin: 0;
  }

  .ps-item :global(img) {
    display: block;
    inline-size: 100%;
    block-size: auto;
  }

  .ps figcaption {
    margin-block-start: var(--space-sm);
    max-width: var(--measure);
    font-size: var(--text-sm);
    color: var(--color-text-muted);
  }

  /* ≥48rem: the real staggered three-column wall with static depth. Scale and
     opacity are layout (not motion), so they apply even under reduced motion. */
  @media (min-width: 48rem) {
    .ps-scene {
      display: flex;
      align-items: flex-start;
      gap: var(--space-lg);
      padding-inline: 0;
    }

    .ps-col {
      display: flex;
      flex-direction: column;
      gap: var(--space-lg);
      flex: 1;
      min-inline-size: 0;
    }

    /* Middle column sits highest; the sides drop for the staggered wall. */
    .ps-col:nth-child(1) {
      margin-block-start: 4.5rem;
    }
    .ps-col:nth-child(3) {
      margin-block-start: 9rem;
    }

    .ps-item {
      inline-size: 90%;
      margin-inline: auto;
      scale: var(--scale, 1);
      opacity: var(--op, 1);
    }
  }

  /* Parallax — only when motion is allowed AND there's room. Drift uses the
     independent `translate` property so it never fights the depth `scale`. */
  @media (prefers-reduced-motion: no-preference) and (min-width: 48rem) {
    .ps-scene {
      view-timeline-name: --ps-tl;
      view-timeline-axis: block;
    }

    /* Preferred: JS-free, scroll-linked, bidirectional parallax. */
    @supports (animation-timeline: view()) {
      .ps-item {
        animation: ps-parallax linear both;
        animation-timeline: --ps-tl;
        animation-range: cover;
      }
    }

    /* Fallback path: phone-scene.ts writes --ps-shift. */
    @supports not (animation-timeline: view()) {
      .ps-item {
        translate: 0 var(--ps-shift, 0px);
      }
    }
  }

  @keyframes ps-parallax {
    from {
      translate: 0 var(--amp);
    }
    to {
      translate: 0 calc(var(--amp) * -1);
    }
  }
</style>

---
import type { CollectionEntry } from 'astro:content';
import { Image } from 'astro:assets';
import Artwork from './artwork/Artwork.astro';

interface Props {
  entry: CollectionEntry<'work'>;
  headingLevel?: 'h2' | 'h3';
  featured?: boolean;
}

const { entry, headingLevel: Heading = 'h3', featured = false } = Astro.props;
const { title, client, year, discipline, artwork, heroImage } = entry.data;
const kind = discipline[0];
---

<article class:list={['project-card', { 'is-featured': featured }]}>
  <a class="card-link" href={`/work/${entry.id}/`} aria-label={title}></a>
  <div class="card-visual">
    {
      heroImage ? (
        <Image
          class="card-photo"
          src={heroImage}
          alt=""
          widths={[700, 1300, 2200]}
          sizes={featured ? '(max-width: 80rem) 100vw, 75rem' : '(max-width: 48rem) 100vw, 38rem'}
        />
      ) : (
        <Artwork {artwork} frameless />
      )
    }
  </div>
  <span class="glass-arrow" aria-hidden="true">
    <svg viewBox="0 0 16 16" width="18" height="18" fill="none">
      <path
        d="M2 8h12m0 0L9 3m5 5-5 5"
        stroke="currentColor"
        stroke-width="1.8"
        stroke-linecap="round"
        stroke-linejoin="round"></path>
    </svg>
  </span>
  <div class="card-overlay">
    <div class="card-id">
      <p class="eyebrow card-meta">{client} · {year}</p>
      <Heading class="card-title">{title}</Heading>
    </div>
    <span class="card-kind">{kind}</span>
  </div>
</article>

<style>
  .project-card {
    position: relative;
    overflow: hidden;
    aspect-ratio: 1 / 1;
    background-color: var(--color-bg-subtle);
    border-radius: var(--radius-2xl);
  }

  .is-featured {
    aspect-ratio: 16 / 9;
  }

  /* Full-bleed link: the whole card is the click target */
  .card-link {
    position: absolute;
    inset: 0;
    z-index: 2;
    border-radius: inherit;
  }

  .card-link:focus-visible {
    outline: 2px solid var(--color-accent);
    outline-offset: 3px;
  }

  @media (max-width: 40rem) {
    .project-card,
    .is-featured {
      aspect-ratio: 1 / 1.05;
    }
  }

  .card-visual {
    position: absolute;
    inset: 0;
    transition: scale 1s var(--ease-out-cubic);
  }

  .card-visual :global(.card-photo) {
    inline-size: 100%;
    block-size: 100%;
    object-fit: cover;
  }

  .project-card:hover .card-visual,
  .project-card:focus-within .card-visual {
    scale: 1.05;
  }

  /* Legibility scrim under the overlay row */
  .card-visual::after {
    content: '';
    position: absolute;
    inset: auto 0 0 0;
    block-size: 45%;
    background: linear-gradient(transparent, color-mix(in srgb, var(--color-bg-subtle) 92%, transparent));
  }

  .glass-arrow {
    position: absolute;
    top: var(--space-lg);
    right: var(--space-lg);
    display: grid;
    place-items: center;
    inline-size: 3.5rem;
    block-size: 3.5rem;
    color: var(--color-glass-text);
    background-color: var(--color-glass-bg);
    border: 1px solid var(--color-glass-border);
    border-radius: var(--radius-full);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    pointer-events: none;
    opacity: 0;
    scale: 0.85;
    transition:
      opacity var(--duration-quick) var(--ease-out-cubic),
      scale var(--duration-quick) var(--ease-out-cubic);
  }

  .project-card:hover .glass-arrow,
  .project-card:focus-within .glass-arrow {
    opacity: 1;
    scale: 1;
  }

  .card-overlay {
    position: absolute;
    inset: auto 0 0 0;
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    gap: var(--space-md);
    padding: var(--space-lg);
    /* Decorative only — the full-card .card-link sits above and takes the clicks */
    pointer-events: none;
  }

  .card-id {
    display: grid;
    gap: var(--space-2xs);
  }

  .card-meta {
    color: var(--color-text-muted);
  }

  .card-title {
    max-width: 22ch;
    font-size: var(--text-xl);
    letter-spacing: var(--tracking-tight);
  }

  .is-featured .card-title {
    font-size: var(--text-2xl);
  }

  .card-kind {
    flex-shrink: 0;
    padding: var(--space-xs) var(--space-md);
    font-size: var(--text-xs);
    font-weight: 600;
    white-space: nowrap;
    color: var(--color-text);
    background-color: color-mix(in srgb, var(--color-surface) 75%, transparent);
    border: 1px solid var(--color-glass-border);
    border-radius: var(--radius-full);
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
  }

  @media (max-width: 28rem) {
    .card-overlay {
      flex-direction: column;
      align-items: flex-start;
      gap: var(--space-sm);
    }

    .card-visual::after {
      block-size: 65%;
    }
  }
</style>

interface Tool {
  name: string;
  category?: string;
  logo: LogoName;
}

interface Props {
  tools: Tool[];
}

const { tools } = Astro.props;
---

<ul role="list" class="tool-grid" data-reveal>
  {
    tools.map((tool, i) => {
      const logo = logos[tool.logo];
      return (
        <li class="tool-card" data-reveal-item data-spotlight style={`--index: ${i}`}>
          <span class="tool-logo" aria-hidden="true">
            <svg
              viewBox={logo.viewBox}
              fill={logo.mode === 'stroke' ? 'none' : 'currentColor'}
              stroke={logo.mode === 'stroke' ? 'currentColor' : undefined}
              role="presentation"
              set:html={logo.body}
            />
          </span>
          <span class="tool-text">
            {tool.category && <span class="tool-category">{tool.category}</span>}
            <span class="tool-name">{tool.name}</span>
          </span>
        </li>
      );
    })
  }
</ul>

<style>
  .tool-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(min(16rem, 100%), 1fr));
    gap: var(--space-md);
    margin: 0;
    padding: 0;
  }

  .tool-card {
    position: relative;
    isolation: isolate;
    overflow: hidden;
    display: flex;
    align-items: center;
    gap: var(--space-md);
    padding: var(--space-lg);
    background-color: var(--color-surface);
    border: var(--border-hairline);
    border-radius: var(--radius-xl);
    transition:
      border-color var(--duration-quick) var(--ease-out-cubic),
      box-shadow var(--duration-quick) var(--ease-out-cubic),
      translate var(--duration-quick) var(--ease-out-cubic);
  }

  /* Pointer spotlight — resume.ts writes --mx/--my; falls back to centered. */
  .tool-card::before {
    content: '';
    position: absolute;
    inset: 0;
    z-index: -1;
    opacity: 0;
    background: radial-gradient(
      14rem circle at var(--mx, 50%) var(--my, 50%),
      var(--color-accent-glow),
      transparent 60%
    );
    transition: opacity var(--duration-quick) var(--ease-out-cubic);
  }

  .tool-card:hover {
    border-color: var(--color-accent);
    box-shadow: 0 10px 28px rgb(0 0 0 / 0.08);
    translate: 0 -4px;
  }

  .tool-card:hover::before {
    opacity: var(--glow-opacity);
  }

  .tool-logo {
    display: grid;
    place-items: center;
    flex-shrink: 0;
    inline-size: 2.75rem;
    block-size: 2.75rem;
    color: var(--color-text);
    background-color: var(--color-bg-subtle);
    border-radius: var(--radius-md);
  }

  .tool-logo svg {
    inline-size: 1.5rem;
    block-size: 1.5rem;
  }

  .tool-text {
    display: flex;
    flex-direction: column;
    min-inline-size: 0;
  }

  .tool-category {
    font-size: var(--text-xs);
    font-weight: 600;
    letter-spacing: var(--tracking-wide);
    text-transform: uppercase;
    color: var(--color-text-muted);
  }

  .tool-name {
    font-size: var(--text-lg);
    font-weight: 650;
    letter-spacing: var(--tracking-tight);
  }
</style>

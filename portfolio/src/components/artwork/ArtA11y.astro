---
// Accessibility: visible focus, contrast pairing, target size.
---

<svg viewBox="0 0 800 450" preserveAspectRatio="xMidYMid slice" aria-hidden="true">
  <!-- focus ring around a control -->
  <rect
    x="92"
    y="158"
    width="280"
    height="100"
    rx="22"
    fill="none"
    stroke="var(--color-accent)"
    stroke-width="3"
    stroke-dasharray="10 8"></rect>
  <rect x="108" y="174" width="248" height="68" rx="14" fill="var(--color-surface)" stroke="var(--color-border-strong)" stroke-width="2"></rect>
  <rect x="146" y="200" width="172" height="14" rx="7" fill="var(--color-text-muted)"></rect>

  <!-- contrast pair -->
  <circle cx="540" cy="150" r="64" fill="var(--color-text)"></circle>
  <circle cx="624" cy="150" r="64" fill="var(--color-surface)" stroke="var(--color-border-strong)" stroke-width="2"></circle>
  <path d="M624 86 a64 64 0 0 1 0 128 Z" fill="var(--color-text)" opacity="0.12"></path>

  <!-- minimum target sizes -->
  <g stroke="var(--color-border-strong)" stroke-width="1.5" fill="none">
    <rect x="488" y="280" width="48" height="48" rx="10"></rect>
    <rect x="560" y="280" width="48" height="48" rx="10"></rect>
    <rect x="632" y="280" width="48" height="48" rx="10"></rect>
  </g>
  <circle cx="584" cy="304" r="8" fill="var(--color-accent)"></circle>
  <circle cx="512" cy="304" r="8" fill="var(--color-text-muted)"></circle>
  <circle cx="656" cy="304" r="8" fill="var(--color-text-muted)"></circle>
</svg>

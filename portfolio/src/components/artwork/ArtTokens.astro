---
// Token cascade: many primitives → few semantic tokens → one component.
const primitives = [
  '#0a0a0a',
  '#4f4f4f',
  '#6d6d6d',
  '#888888',
  '#b0b0b0',
  '#d1d1d1',
  '#e1fc06',
  '#c9e205',
  '#b3674f',
  '#5e7b99',
];
const semanticY = [120, 185, 250, 315];
---

<svg viewBox="0 0 800 450" preserveAspectRatio="xMidYMid slice" aria-hidden="true">
  <!-- primitives: a dense column of raw values -->
  {primitives.map((hue, i) => <circle cx="100" cy={62 + i * 36} r="11" fill={hue} stroke="var(--color-border)" />)}

  <!-- flow lines -->
  {
    semanticY.map((y) => (
      <path
        d={`M120 ${100 + (y - 120) * 0.85} C 200 ${100 + (y - 120) * 0.85}, 220 ${y + 16}, 296 ${y + 16}`}
        fill="none"
        stroke="var(--color-border-strong)"
        stroke-width="1.5"
      />
    ))
  }
  {
    semanticY.map((y) => (
      <path
        d={`M448 ${y + 16} C 520 ${y + 16}, 540 217, 600 217`}
        fill="none"
        stroke="var(--color-border-strong)"
        stroke-width="1.5"
      />
    ))
  }

  <!-- semantic tier: fewer, named shapes -->
  {
    semanticY.map((y, i) => (
      <g>
        <rect x="296" y={y} width="152" height="32" rx="16" fill="var(--color-surface)" stroke="var(--color-border-strong)" />
        <circle cx="316" cy={y + 16} r="7" fill={i === 3 ? 'var(--color-accent)' : 'var(--color-text-muted)'} />
        <rect x="332" y={y + 12} width="96" height="8" rx="4" fill="var(--color-border-strong)" />
      </g>
    ))
  }

  <!-- component: one consumer -->
  <rect x="600" y="152" width="148" height="130" rx="14" fill="var(--color-surface)" stroke="var(--color-border)"></rect>
  <rect x="622" y="178" width="76" height="10" rx="5" fill="var(--color-text-muted)"></rect>
  <rect x="622" y="200" width="104" height="7" rx="3.5" fill="var(--color-border-strong)"></rect>
  <rect x="622" y="214" width="88" height="7" rx="3.5" fill="var(--color-border-strong)"></rect>
  <rect x="622" y="238" width="64" height="24" rx="7" fill="var(--color-accent)"></rect>
</svg>

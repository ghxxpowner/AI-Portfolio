---
import BaseLayout from '../layouts/BaseLayout.astro';
import GlowBlob from '../components/GlowBlob.astro';
import PillButton from '../components/PillButton.astro';
import StatCards from '../components/StatCards.astro';

const bigStats = [
  { value: '10+', label: 'years in digital product design', variant: 'surface' as const },
  { value: '12', label: 'brands carried by one design system', variant: 'gradient' as const },
  { value: '23', label: 'product squads shipping on my systems', variant: 'ink' as const },
  { value: 'AA', label: 'WCAG 2.2 — verified by independent audit', variant: 'neon' as const },
];

const capabilities = [
  {
    area: 'Token architecture',
    detail: 'Primitive → semantic → component tiering, naming systems, theming contracts, dark mode and multi-brand strategies.',
  },
  {
    area: 'Component design',
    detail: 'Specs that cover behavior, anatomy, accessibility and API — written with the engineers who build them.',
  },
  {
    area: 'Governance & adoption',
    detail: 'Contribution models, review SLAs, lifecycle states and adoption instrumentation that make systems self-sustaining.',
  },
  {
    area: 'Accessibility',
    detail: 'WCAG 2.2 AA as a system property: contrast-verified ramps, focus standards, executable acceptance criteria.',
  },
  {
    area: 'Design–code workflow',
    detail: 'Figma library architecture, variables, Code Connect and the handoff rituals that keep both sources of truth honest.',
  },
  {
    area: 'Systems strategy',
    detail: 'Making the business case: what to systematize, what to leave alone, and how to report value to leadership.',
  },
];

const experience = [
  { period: '2022 — today', role: 'Product Designer, Design Systems', org: 'Jakala' },
  { period: '2019 — 2022', role: 'Product Designer', org: 'Digital product agency' },
  { period: '2016 — 2019', role: 'UI/Visual Designer', org: 'Brand & digital studio' },
];

const jsonLd = JSON.stringify({
  '@context': 'https://schema.org',
  '@type': 'Person',
  name: 'Daniel Klinke',
  jobTitle: 'Product Designer, Design Systems',
  url: 'https://danielklinke.design',
  sameAs: ['https://www.linkedin.com/in/danielklinke'],
});
---

<BaseLayout
  title="About"
  description="Daniel Klinke is a product designer specializing in design systems — token architecture, component libraries, governance and accessibility."
>
  <script type="application/ld+json" set:html={jsonLd} slot="head" />
  <div class="container">
    <header class="page-head" data-reveal>
      <GlowBlob size="36rem" top="-16rem" left="-14rem" />
      <h1 class="display" data-split="chars">About</h1>
      <div class="bio flow" data-split="lines">
        <p>
          I'm Daniel Klinke, a product designer focused on design systems — the tokens, components,
          documentation and governance that let many teams ship one coherent product. I've built
          systems that carry a single brand and systems that carry twelve, migrated legacy style
          guides to token architectures, and turned stalled libraries into contributed-to
          infrastructure.
        </p>
        <p>
          What I care about is adoption. A system is only as good as the screens teams actually
          build with it, so I spend as much time on contribution processes, review SLAs and
          adoption metrics as on the components themselves. The craft matters — but the craft has
          to survive contact with twenty product squads and a deadline.
        </p>
        <p>
          The best way to understand how I work is to read the <a href="/work/">case studies</a> —
          they're written the way I ran the projects, decisions and trade-offs included.
        </p>
      </div>
    </header>

    <section class="stats-block" aria-label="Key numbers" data-reveal>
      <StatCards stats={bigStats} />
    </section>

    <section class="block" aria-labelledby="capabilities-heading" data-reveal>
      <h2 id="capabilities-heading" class="display section-title" data-reveal-item style="--index: 0">
        What I do
      </h2>
      <dl class="capabilities">
        {
          capabilities.map((c, i) => (
            <div class="capability" data-reveal-item style={`--index: ${i + 1}`}>
              <p class="capability-num" aria-hidden="true">{String(i + 1).padStart(2, '0')}</p>
              <dt>{c.area}</dt>
              <dd>{c.detail}</dd>
            </div>
          ))
        }
      </dl>
    </section>

    <section class="block" aria-labelledby="experience-heading" data-reveal>
      <h2 id="experience-heading" class="display section-title" data-reveal-item style="--index: 0">
        Experience
      </h2>
      <ul role="list" class="experience">
        {
          experience.map((e, i) => (
            <li class="exp-item" data-reveal-item style={`--index: ${i + 1}`}>
              <span class="exp-period">{e.period}</span>
              <span class="exp-role">{e.role}</span>
              <span class="exp-org">{e.org}</span>
            </li>
          ))
        }
      </ul>
    </section>

    <section class="block" id="contact" aria-labelledby="contact-heading" data-reveal>
      <h2 id="contact-heading" class="display section-title" data-reveal-item style="--index: 0">
        Contact
      </h2>
      <p class="contact-text" data-reveal-item style="--index: 1">
        The fastest way to reach me is email. I'm happy to talk about design-system audits, token
        architecture, governance — or to walk you through any of the case studies in more depth.
      </p>
      <div class="contact-actions" data-reveal-item style="--index: 2">
        <PillButton href="mailto:hello@danielklinke.design">hello@danielklinke.design</PillButton>
        <PillButton href="https://www.linkedin.com/in/danielklinke" variant="ghost">LinkedIn</PillButton>
      </div>
    </section>
  </div>
</BaseLayout>

<style>
  .page-head {
    position: relative;
    display: grid;
    gap: var(--space-xl);
    padding-block: var(--space-4xl) var(--space-3xl);
  }

  h1 {
    font-size: var(--text-display);
  }

  .bio {
    max-width: var(--measure);
  }

  .bio p {
    font-size: var(--text-lg);
    line-height: var(--leading-normal);
  }

  .bio a {
    text-decoration-color: var(--color-accent);
    text-decoration-thickness: 2px;
  }

  .stats-block {
    padding-block-end: var(--space-3xl);
  }

  .block {
    padding-block: var(--space-3xl);
  }

  .section-title {
    font-size: var(--text-3xl);
    margin-block-end: var(--space-2xl);
  }

  .capabilities {
    display: grid;
    gap: var(--space-lg);
    margin: 0;
  }

  @media (min-width: 48rem) {
    .capabilities {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  .capability {
    display: grid;
    align-content: start;
    gap: var(--space-sm);
    padding: var(--space-xl);
    background-color: var(--color-surface);
    border-radius: var(--radius-2xl);
  }

  .capability-num {
    inline-size: fit-content;
    padding: var(--space-2xs) var(--space-sm);
    font-family: var(--font-mono);
    font-size: var(--text-sm);
    font-weight: 600;
    color: var(--color-on-accent);
    background-color: var(--color-accent);
    border-radius: var(--radius-full);
  }

  .capability dt {
    margin-block-start: var(--space-sm);
    font-size: var(--text-xl);
    font-weight: 650;
    letter-spacing: var(--tracking-tight);
  }

  .capability dd {
    margin: 0;
    font-size: var(--text-sm);
    color: var(--color-text-muted);
    text-wrap: pretty;
  }

  .experience {
    display: grid;
    gap: var(--space-sm);
    max-width: var(--measure);
  }

  .exp-item {
    display: grid;
    grid-template-columns: auto 1fr auto;
    gap: var(--space-md);
    align-items: center;
    padding: var(--space-md) var(--space-lg);
    background-color: var(--color-surface);
    border-radius: var(--radius-xl);
  }

  @media (max-width: 40rem) {
    .exp-item {
      grid-template-columns: 1fr;
      gap: var(--space-2xs);
      align-items: start;
    }
  }

  .exp-period {
    inline-size: fit-content;
    padding: var(--space-2xs) var(--space-sm);
    font-size: var(--text-xs);
    font-weight: 600;
    letter-spacing: var(--tracking-wide);
    text-transform: uppercase;
    color: var(--color-text);
    background-color: var(--color-bg);
    border-radius: var(--radius-full);
    font-variant-numeric: tabular-nums;
    white-space: nowrap;
  }

  .exp-role {
    font-weight: 600;
  }

  .exp-org {
    font-size: var(--text-sm);
    color: var(--color-text-muted);
  }

  .contact-text {
    max-width: var(--measure);
    font-size: var(--text-lg);
  }

  .contact-actions {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-sm);
    margin-block-start: var(--space-lg);
  }
</style>

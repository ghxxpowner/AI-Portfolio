---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import ProjectCard from '../components/ProjectCard.astro';
import PillButton from '../components/PillButton.astro';
import HeroMesh from '../components/HeroMesh.astro';
import Marquee from '../components/Marquee.astro';

const featured = (await getCollection('work', ({ data }) => data.featured && !data.draft)).sort(
  (a, b) => a.data.order - b.data.order
);
---

<BaseLayout
  title="Daniel Klinke"
  description="Product designer specializing in design systems — token architecture, multi-brand theming, governance and accessibility. Selected case studies."
>
  <section class="hero container" data-reveal>
    <HeroMesh />
    <h1 class="display" data-split="chars">Design systems that teams adopt</h1>
    <div data-split="lines">
      <p class="hero-sub">
        I'm Daniel Klinke, product designer. I design token architectures, multi-brand component
        libraries and the governance that keeps them alive — for products with many teams and no
        patience for friction.
      </p>
      <p class="hero-meta">Based in Germany · Working with teams worldwide</p>
    </div>
  </section>

  <section class="container work-section" id="featured" aria-labelledby="featured-heading" data-reveal>
    <div class="section-head" data-reveal-item style="--index: 0">
      <h2 id="featured-heading" class="display section-title">Work</h2>
    </div>
    <div class="work-grid">
      {
        featured.map((entry, i) => (
          <div class:list={[{ 'grid-featured': i === 0 }]} data-reveal-item style={`--index: ${i + 1}`}>
            <ProjectCard {entry} featured={i === 0} />
          </div>
        ))
      }
    </div>
    <div class="work-more" data-reveal-item style={`--index: ${featured.length + 1}`}>
      <PillButton href="/work/" variant="ghost">All case studies</PillButton>
    </div>
  </section>

  <section class="engagement-section" aria-hidden="true">
    <div class="marquee-head">
      <Marquee items={['Ways to work together']} size="xl" borderless />
    </div>
  </section>
</BaseLayout>

<style>
  .hero {
    position: relative;
    display: grid;
    justify-items: start;
    gap: var(--space-xl);
    padding-block: var(--space-6xl) var(--space-4xl);
    overflow: visible;
  }

  h1 {
    max-width: 10ch;
    font-size: var(--text-display);
  }

  .hero-sub {
    max-width: 52ch;
    font-size: var(--text-lg);
    line-height: var(--leading-snug);
    color: var(--color-text-muted);
    text-wrap: pretty;
  }

  .hero-meta {
    margin-block-start: var(--space-md);
    font-size: var(--text-sm);
    color: var(--color-text-muted);
  }

  .work-section {
    padding-block-start: var(--space-6xl);
  }

  /* Animated band below the work grid */
  .engagement-section {
    padding-block-start: var(--space-6xl);
  }

  .marquee-head {
    margin-block-end: var(--space-2xl);
  }

  .work-section .section-head {
    margin-block-end: var(--space-2xl);
  }

  .section-title {
    font-size: var(--text-5xl);
  }

  .work-grid {
    display: grid;
    gap: var(--space-md);
  }

  @media (min-width: 48rem) {
    .work-grid {
      grid-template-columns: 1fr 1fr;
    }

    .grid-featured {
      grid-column: 1 / -1;
    }
  }

  .work-more {
    display: flex;
    justify-content: center;
    margin-block-start: var(--space-xl);
  }
</style>

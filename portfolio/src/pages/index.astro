---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import ProjectCard from '../components/ProjectCard.astro';
import PillButton from '../components/PillButton.astro';
import HeroMesh from '../components/HeroMesh.astro';
import Marquee from '../components/Marquee.astro';

const featured = (await getCollection('work', ({ data }) => data.featured && !data.draft)).sort(
  (a, b) => a.data.order - b.data.order
);
---

<BaseLayout
  title="Daniel Klinke"
  description="Product designer specializing in design systems — token architecture, multi-brand theming, governance and accessibility. Selected case studies."
>
  <section class="hero container" data-reveal>
    <HeroMesh />
    <p class="hero-eyebrow eyebrow" data-reveal-item style="--index: 0">
      Product Designer · Design Systems
    </p>
    <h1 class="display hero-title" data-reveal-item style="--index: 1">
      Hi, I'm Daniel!<br />
      I create{' '}
      <span class="rotator" data-rotator aria-hidden="true">
        <span class="rotator-word is-active">Digital products</span>
        <span class="rotator-word">Design Systems</span>
        <span class="rotator-word">Interfaces</span>
        <span class="rotator-word">&amp; Creative Stuff</span>
      </span>
      <span class="visually-hidden"> digital products.</span>
    </h1>
    <p class="hero-sub" data-reveal-item style="--index: 2">
      I'm Daniel Klinke — I build the tokens, components and governance that keep multi-brand
      products coherent.
    </p>
    <p class="hero-meta" data-reveal-item style="--index: 3">
      Based in Germany · Working with teams worldwide
    </p>
  </section>

  <section class="container work-section" id="featured" aria-labelledby="featured-heading" data-reveal>
    <div class="section-head" data-reveal-item style="--index: 0">
      <h2 id="featured-heading" class="display section-title">Work</h2>
    </div>
    <div class="work-grid">
      {
        featured.map((entry, i) => (
          <div class:list={[{ 'grid-featured': i === 0 }]} data-reveal-item style={`--index: ${i + 1}`}>
            <ProjectCard {entry} featured={i === 0} />
          </div>
        ))
      }
    </div>
    <div class="work-more" data-reveal-item style={`--index: ${featured.length + 1}`}>
      <PillButton href="/work/" variant="ghost">All case studies</PillButton>
    </div>
  </section>

  <section class="engagement-section" aria-hidden="true">
    <div class="marquee-head">
      <Marquee items={['Ways to work together']} size="xl" borderless />
    </div>
  </section>
</BaseLayout>

<style>
  .hero {
    position: relative;
    display: grid;
    justify-items: start;
    gap: var(--space-md);
    padding-block: var(--space-6xl) var(--space-4xl);
    overflow: visible;
  }

  .hero-eyebrow {
    margin-block-end: var(--space-2xs);
  }

  .hero-title {
    max-width: 20ch;
    font-size: var(--text-5xl);
    line-height: var(--leading-tight);
  }

  /* Kinetic rotating word. inline-grid stacks all words in one cell, so the box
     sizes to the widest word and never reflows as they swap. */
  .rotator {
    display: inline-grid;
    vertical-align: baseline;
  }

  .rotator-word {
    grid-area: 1 / 1;
    color: var(--color-accent);
    white-space: nowrap;
    opacity: 0;
  }

  .rotator-word.is-active {
    opacity: 1;
  }

  @media (prefers-reduced-motion: no-preference) {
    .rotator-word {
      translate: 0 0.35em;
      filter: blur(6px);
      transition:
        opacity var(--duration-slow) var(--ease-out-cubic),
        translate var(--duration-slow) var(--ease-out-cubic),
        filter var(--duration-slow) var(--ease-out-cubic);
    }

    .rotator-word.is-active {
      translate: 0 0;
      filter: blur(0);
    }
  }

  .hero-sub {
    max-width: 46ch;
    margin-block-start: var(--space-sm);
    font-size: var(--text-lg);
    line-height: var(--leading-snug);
    color: var(--color-text-muted);
    text-wrap: pretty;
  }

  .hero-meta {
    font-size: var(--text-sm);
    color: var(--color-text-muted);
  }

  .work-section {
    padding-block-start: var(--space-3xl);
  }

  /* Animated band below the work grid */
  .engagement-section {
    padding-block-start: var(--space-6xl);
  }

  .marquee-head {
    margin-block-end: var(--space-2xl);
  }

  .work-section .section-head {
    margin-block-end: var(--space-2xl);
  }

  .section-title {
    font-size: var(--text-5xl);
  }

  .work-grid {
    display: grid;
    gap: var(--space-md);
  }

  @media (min-width: 48rem) {
    .work-grid {
      grid-template-columns: 1fr 1fr;
    }

    .grid-featured {
      grid-column: 1 / -1;
    }
  }

  .work-more {
    display: flex;
    justify-content: center;
    margin-block-start: var(--space-xl);
  }
</style>

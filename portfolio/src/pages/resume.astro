---
import BaseLayout from '../layouts/BaseLayout.astro';
import GlowBlob from '../components/GlowBlob.astro';
import PillButton from '../components/PillButton.astro';
import StatCards from '../components/StatCards.astro';
import AvatarPortrait from '../components/AvatarPortrait.astro';
import ExperienceTimeline from '../components/ExperienceTimeline.astro';
import AreaList from '../components/AreaList.astro';
import ToolGrid from '../components/ToolGrid.astro';
import SkillTags from '../components/SkillTags.astro';

// Real numbers, shared with the About page.
const bigStats = [
  { value: '10+', label: 'years in digital product design', variant: 'surface' as const },
  { value: '12', label: 'brands carried by one design system', variant: 'gradient' as const },
  { value: '23', label: 'product squads shipping on my systems', variant: 'ink' as const },
  { value: 'AA', label: 'WCAG 2.2 — verified by independent audit', variant: 'neon' as const },
];

// Areas of specialization — where I've built real expertise.
const areas = [
  'Art Direction',
  'Design Strategy',
  'Design Systems',
  'Frontend Development',
  'GenAI Integration',
  'Inclusive Design (WCAG)',
  'Information Architecture',
  'Interaction Design',
  'Motion Design',
  'Product Design (UI/UX)',
  'Prototyping',
  'Streaming Platforms',
  'Typography',
  'User Research',
  'Vibe Coding',
  'Visual Identity',
];

// Tools & programs I work in day to day.
const tools = [
  { name: 'Figma', category: 'Design & systems', logo: 'figma' as const },
  { name: 'Claude', category: 'AI pair', logo: 'claude' as const },
  { name: 'Antigravity', category: 'Agentic IDE', logo: 'antigravity' as const },
  { name: 'GitHub', category: 'Version control', logo: 'github' as const },
  { name: 'Illustrator', category: 'Vector & brand', logo: 'illustrator' as const },
  { name: 'Photoshop', category: 'Imaging', logo: 'photoshop' as const },
  { name: 'Premiere Pro', category: 'Video', logo: 'premierepro' as const },
  { name: 'Midjourney', category: 'AI imagery', logo: 'midjourney' as const },
  { name: 'Webflow', category: 'Web build', logo: 'webflow' as const },
  { name: 'Storybook', category: 'Design–code', logo: 'storybook' as const },
  { name: 'Jira', category: 'Delivery', logo: 'jira' as const },
];

// Private skills — realistic placeholders, easy to edit.
const privateSkills = [
  { label: 'Photography', icon: 'camera' as const },
  { label: 'Road cycling', icon: 'bike' as const },
  { label: 'Specialty coffee', icon: 'coffee' as const },
  { label: 'Bouldering', icon: 'climb' as const },
  { label: 'Vinyl & synths', icon: 'music' as const },
  { label: 'Travel & languages', icon: 'globe' as const },
  { label: 'Design literature', icon: 'book' as const },
  { label: 'Urban gardening', icon: 'plant' as const },
];

const jsonLd = JSON.stringify({
  '@context': 'https://schema.org',
  '@type': 'ProfilePage',
  mainEntity: {
    '@type': 'Person',
    name: 'Daniel Klinke',
    jobTitle: 'Product Designer, Design Systems',
    url: 'https://danielklinke.design',
    sameAs: ['https://www.linkedin.com/in/danielklinke'],
    knowsAbout: tools.map((t) => t.name),
  },
});
---

<BaseLayout
  title="Resume"
  description="The interactive resume of Daniel Klinke — career timeline, design-systems skills and the person behind the work."
>
  <script type="application/ld+json" set:html={jsonLd} slot="head" />
  <div class="container">
    <!-- Intro / profile -->
    <header class="intro" data-reveal>
      <GlowBlob size="40rem" top="-18rem" left="-14rem" />
      <div class="intro-text">
        <p class="eyebrow" data-reveal-item style="--index: 0">Product Designer · Design Systems</p>
        <h1 class="display" data-split="chars">Daniel Klinke</h1>
        <div class="intro-bio flow" data-split="lines">
          <p>
            I design the tokens, components, documentation and governance that let many teams ship
            one coherent product — and I care most about whether those systems actually get adopted.
          </p>
          <p>
            Based in Germany, working with teams worldwide. Below: how I got here, what I'm deep in,
            and a little of who I am away from the canvas.
          </p>
        </div>
        <div class="intro-actions" data-reveal-item style="--index: 4">
          <PillButton href="mailto:hello@danielklinke.design">Get in touch</PillButton>
          <PillButton href="/work/" variant="ghost">See the work</PillButton>
        </div>
      </div>
      <div class="intro-portrait" data-reveal-item style="--index: 3">
        <AvatarPortrait name="Daniel Klinke" />
      </div>
    </header>

    <!-- Key numbers -->
    <section class="block" aria-label="Key numbers" data-reveal>
      <StatCards stats={bigStats} />
    </section>

    <!-- Career timeline -->
    <section class="block" aria-labelledby="timeline-heading">
      <div data-reveal>
        <h2 id="timeline-heading" class="display section-title" data-reveal-item style="--index: 0">
          Career
        </h2>
        <p class="section-sub" data-reveal-item style="--index: 1">
          A decade moving from visual craft toward the systems that scale it.
        </p>
      </div>
      <ExperienceTimeline />
    </section>

    <!-- Areas of specialization -->
    <section class="block" aria-labelledby="areas-heading">
      <div data-reveal>
        <p class="section-eyebrow" data-reveal-item style="--index: 0">Specializations</p>
        <h2 id="areas-heading" class="display section-title" data-reveal-item style="--index: 1">
          Areas
        </h2>
        <p class="section-sub" data-reveal-item style="--index: 2">
          Where I'm at home and have built real depth — so you can tell at a glance whether I'm the
          right fit for your problem.
        </p>
      </div>
      <AreaList {areas} />
    </section>

    <!-- Tools & programs -->
    <section class="block" aria-labelledby="skills-heading">
      <div data-reveal>
        <h2 id="skills-heading" class="display section-title" data-reveal-item style="--index: 0">
          What I'm deep in
        </h2>
        <p class="section-sub" data-reveal-item style="--index: 1">
          The programs I reach for daily — from design and motion to documentation and code. Hover a
          card to bring it forward.
        </p>
      </div>
      <ToolGrid {tools} />
    </section>

    <!-- Private skills -->
    <section class="block" aria-labelledby="private-heading">
      <div data-reveal>
        <h2 id="private-heading" class="display section-title" data-reveal-item style="--index: 0">
          Away from the screen
        </h2>
        <p class="section-sub" data-reveal-item style="--index: 1">
          The interests that keep my eye fresh and my weekends full.
        </p>
      </div>
      <SkillTags items={privateSkills} />
    </section>
  </div>
</BaseLayout>

<style>
  .intro {
    position: relative;
    display: grid;
    gap: var(--space-2xl);
    align-items: center;
    padding-block: var(--space-4xl) var(--space-3xl);
  }

  @media (min-width: 52rem) {
    .intro {
      grid-template-columns: 1.4fr 1fr;
      gap: var(--space-3xl);
    }
  }

  .intro-text {
    display: grid;
    gap: var(--space-lg);
  }

  h1 {
    font-size: var(--text-display);
  }

  .eyebrow {
    font-size: var(--text-sm);
    font-weight: 600;
    letter-spacing: var(--tracking-wide);
    text-transform: uppercase;
    color: var(--color-text-muted);
  }

  .intro-bio {
    max-width: var(--measure);
  }

  .intro-bio p {
    font-size: var(--text-lg);
    line-height: var(--leading-normal);
  }

  .intro-actions {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-sm);
    margin-block-start: var(--space-xs);
  }

  .intro-portrait {
    max-width: 24rem;
    inline-size: 100%;
    justify-self: center;
  }

  @media (min-width: 52rem) {
    .intro-portrait {
      justify-self: end;
    }
  }

  .block {
    padding-block: var(--space-3xl);
  }

  .section-eyebrow {
    display: inline-flex;
    margin-block-end: var(--space-md);
    padding: var(--space-2xs) var(--space-md);
    font-size: var(--text-xs);
    font-weight: 600;
    letter-spacing: var(--tracking-wide);
    text-transform: uppercase;
    color: var(--color-text);
    background-color: var(--color-bg-subtle);
    border-radius: var(--radius-full);
  }

  .section-title {
    font-size: var(--text-3xl);
    margin-block-end: var(--space-sm);
  }

  .section-sub {
    max-width: var(--measure);
    margin-block-end: var(--space-2xl);
    font-size: var(--text-lg);
    color: var(--color-text-muted);
    text-wrap: pretty;
  }
</style>
